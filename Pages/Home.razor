@page "/"
@using MarchMadnessBlazor.Models
@using MarchMadnessBlazor.Services
@using MarchMadnessBlazor.Components
@inject BracketService Svc
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>March Madness 2024</PageTitle>

<div class="bracket-page">

    <div class="bracket-toolbar">
        <h1 class="bracket-title">NCAA March Madness 2024</h1>
        <div class="toolbar-actions">
            @if (!Svc.State.IsSimulated)
            {
                <button class="btn btn-primary" @onclick="Svc.Simulate">Simulate</button>
            }
            <button class="btn btn-reset" @onclick="Svc.Reset">Reset</button>
            <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/settings")'>&#9881; Settings</button>
        </div>
        <div class="toolbar-score">
            @if (Svc.State.IsSimulated)
            {
                <span class="score-total">Score: @Svc.State.TotalScore().ToString("N0") / 1,920</span>
                <div class="score-breakdown">
                    @for (int r = 1; r <= 6; r++)
                    {
                        var round = r;
                        <span>@BracketState.RoundNames[round]: @Svc.State.RoundScore(round)</span>
                    }
                </div>
            }
            else
            {
                <span class="picks-progress">@Svc.State.PicksComplete() / 63 picks made — or click Simulate to run instantly</span>
            }
        </div>
    </div>

    <div class="bracket-scroll">
        <div class="bracket-wrapper">

            <!-- Left half: East (top) + South (bottom) advancing right -->
            <div class="bracket-half bracket-left">
                <BracketRegion RegionIndex="0" />
                <BracketRegion RegionIndex="1" />
            </div>

            <!-- Center: FF + Championship -->
            <div class="bracket-center">
                <div class="center-label">Final Four &amp; Championship</div>
                <div class="center-games">

                    <div class="ff-game">
                        <div class="ff-label">East / South</div>
                        @{ var (ff0t, ff0b) = Svc.State.GetGameTeams(Svc.State.UserPicks, 5, 0); }
                        <GameSlot TopTeam=@ff0t BottomTeam=@ff0b
                                  UserWinner=@Svc.State.UserPicks[5][0]
                                  SimWinner=@Svc.State.SimResults[5][0]
                                  IsSimulated=@Svc.State.IsSimulated
                                  OnPick=@(t => Svc.Pick(5, 0, t)) />
                    </div>

                    <div class="ff-game championship">
                        <div class="ff-label">&#127942; Championship</div>
                        @{ var (cht, chb) = Svc.State.GetGameTeams(Svc.State.UserPicks, 6, 0); }
                        <GameSlot TopTeam=@cht BottomTeam=@chb
                                  UserWinner=@Svc.State.UserPicks[6][0]
                                  SimWinner=@Svc.State.SimResults[6][0]
                                  IsSimulated=@Svc.State.IsSimulated
                                  OnPick=@(t => Svc.Pick(6, 0, t)) />
                        @if (Svc.State.IsSimulated && Svc.State.SimResults[6][0] != null)
                        {
                            <div class="champion-banner">&#127942; @Svc.State.SimResults[6][0]!.Name</div>
                        }
                    </div>

                    <div class="ff-game">
                        <div class="ff-label">West / Midwest</div>
                        @{ var (ff1t, ff1b) = Svc.State.GetGameTeams(Svc.State.UserPicks, 5, 1); }
                        <GameSlot TopTeam=@ff1t BottomTeam=@ff1b
                                  UserWinner=@Svc.State.UserPicks[5][1]
                                  SimWinner=@Svc.State.SimResults[5][1]
                                  IsSimulated=@Svc.State.IsSimulated
                                  OnPick=@(t => Svc.Pick(5, 1, t)) />
                    </div>

                </div>
            </div>

            <!-- Right half: West (top) + Midwest (bottom) advancing left (reversed columns) -->
            <div class="bracket-half bracket-right">
                <BracketRegion RegionIndex="2" Reversed="true" />
                <BracketRegion RegionIndex="3" Reversed="true" />
            </div>

        </div>
    </div>

</div>

@code {
    protected override void OnInitialized() => Svc.OnChange += StateHasChanged;
    public void Dispose()                   => Svc.OnChange -= StateHasChanged;
}
