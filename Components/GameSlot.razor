@using MarchMadnessBlazor.Models

<div class="game-slot">
    <div class="team-row @TeamClass(TopTeam)" @onclick="() => HandlePick(TopTeam)">
        @if (TopTeam != null)
        {
            <span class="team-seed">@TopTeam.Seed</span>
            <span class="team-name">@TopTeam.Name</span>
        }
        else { <span class="team-tbd">TBD</span> }
    </div>
    <div class="team-row @TeamClass(BottomTeam)" @onclick="() => HandlePick(BottomTeam)">
        @if (BottomTeam != null)
        {
            <span class="team-seed">@BottomTeam.Seed</span>
            <span class="team-name">@BottomTeam.Name</span>
        }
        else { <span class="team-tbd">TBD</span> }
    </div>
    @if (IsSimulated && ActualWinner != null && SimWinner != null && SimWinner != ActualWinner)
    {
        <div class="actual-result">
            <span class="actual-label">Actually:</span>
            <span class="actual-team">@ActualWinner.Name</span>
            @if (ActualScore != null)
            {
                <span class="actual-score">@ActualScore.WinnerScore–@ActualScore.LoserScore</span>
            }
        </div>
    }
</div>

@code {
    [Parameter] public Team? TopTeam      { get; set; }
    [Parameter] public Team? BottomTeam   { get; set; }
    [Parameter] public Team? UserWinner   { get; set; }
    [Parameter] public Team? SimWinner    { get; set; }
    [Parameter] public Team? ActualWinner { get; set; }
    [Parameter] public GameScore? ActualScore { get; set; }
    [Parameter] public bool  IsSimulated  { get; set; }
    [Parameter] public EventCallback<Team> OnPick { get; set; }

    private string TeamClass(Team? team)
    {
        if (team == null) return "empty";
        var css = new List<string>();
        if (UserWinner == team) css.Add("picked");
        if (IsSimulated && SimWinner != null)
        {
            if (SimWinner == team) css.Add("sim-winner");
            if (UserWinner == team)
                css.Add(UserWinner == SimWinner ? "correct" : "wrong");
        }
        if (IsSimulated && ActualWinner != null && ActualWinner == team && SimWinner != ActualWinner)
            css.Add("actual-winner");
        return string.Join(" ", css);
    }

    private void HandlePick(Team? team)
    {
        if (team != null && !IsSimulated)
            OnPick.InvokeAsync(team);
    }
}
